# Notion is the single source of truth for portfolio content.
# Create a Notion internal integration, share the portfolio category databases
# and public rendering page with it, then set the token below locally or as a CI
# secret.
NOTION_TOKEN=

# Database ids for the "KYS — Portfolio (CMS)" Notion workspace.
# These already have defaults baked into scripts/notion-content.mjs, so you
# only need to set them to point the pipeline at a different workspace.
NOTION_PROFILE_DB_ID=9b24921c-efa4-4143-9ede-abe607300b32
NOTION_INTRO_DB_ID=fa9e9444-6254-4088-9bde-69c556ad3d58
