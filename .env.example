# Notion is the single source of truth for portfolio content.
# Create a read-only Notion internal integration, share each portfolio
# database with it, then set the token below (locally) or as a CI secret.
NOTION_TOKEN=

# Database ids for the "KYS — Portfolio (CMS)" Notion workspace.
# These already have defaults baked into scripts/notion-content.mjs, so you
# only need to set them to point the pipeline at a different workspace.
NOTION_ENTRIES_DB_ID=a15aff41-47f3-4a92-8dc8-a1367ae00a46
