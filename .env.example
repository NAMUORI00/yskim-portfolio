# Notion is the single source of truth for portfolio content.
# Create a read-only Notion internal integration, share each portfolio
# database with it, then set the token below (locally) or as a CI secret.
NOTION_TOKEN=

# Database ids for the "KYS — Portfolio (CMS)" Notion workspace.
# These already have defaults baked into scripts/notion-content.mjs, so you
# only need to set them to point the pipeline at a different workspace.
NOTION_ENTRIES_DB_ID=a15aff41-47f3-4a92-8dc8-a1367ae00a46

# Legacy section DB ids. The fetch pipeline reads NOTION_ENTRIES_DB_ID first and
# only falls back to these if the unified DB is unavailable or empty.
NOTION_PROFILE_DB_ID=b5e3e644-61eb-4d9d-ae2d-61a2f3f44fd1
NOTION_SITE_DB_ID=b657b70e-6dbd-40b3-9b2d-4d4e5e02ba3d
NOTION_CONTACTS_DB_ID=d67538d1-3374-4190-9c63-291dea15e5b7
NOTION_TIMELINE_DB_ID=19648412-cd85-4edf-a688-b1830f8d4aa8
NOTION_PROJECTS_DB_ID=b2bdcda8-4d69-47dd-a334-e519de027888
NOTION_RESEARCH_DB_ID=c8fadc0e-3148-4e1e-9593-0ee144cb4498
NOTION_NOTES_DB_ID=763f7111-ec1e-4d2d-8d6c-54a22bee930b
NOTION_SKILLS_DB_ID=3dfa6886-7b83-41b2-95f5-a0665fb7dcaf
NOTION_STARRED_DB_ID=7800c04b-8f20-4521-9427-bfd0c373bbe2

